#!/bin/bash

# md2pdf
#   by Martin Keegan, (c) 2018
#
# Take a markdown file and output a nice PDF of it
#
# This tool is capable of being used as a UNIX-style pipe.
#
# Usage:
#
#   md2pdf foo.md
#
# or
#
#   md2pdf < foo.md > foo.pdf
#
# or
#
#   md2pdf foo # deprecated - should use full filename
#
#
# Optionally, one may specify the `--sans' argument, to use a sans-serif
# font.
#
#
# To the extent, if any, to which this is protected by copyright, this
# software is available under the Apache Software Licence v2.0

set -eu


# Set up headers

TMPINPUT=$(mktemp --suffix=.md)
cat > $TMPINPUT <<EOF
---
urlcolor: blue
colorlinks: true
pdfcreator: ""
pdfproducer: ""
---
EOF

TMPHEADER=$(mktemp --suffix=.tex)
cat > $TMPHEADER <<EOF
\AtBeginDocument{
  \hypersetup{
    pdfcreator={},
    pdfproducer={}
  }
}

EOF

TMPPDF=$(mktemp --suffix=.pdf)

# Register cleanup for headers

maincleanup () {
  local ev=$?
  rm -f -- $TMPINPUT $TMPHEADER $TMPPDF
  exit $ev
}

trap maincleanup EXIT

has_suffix () {
  # Does the filename name have the right suffix?
  # e.g., "has_suffic main.c .c" returns true
  [ $(basename "$1" "$2") != $(basename "$1") ]
}

source_file_name () {
  local filename="$1"
  local incomplete_filename="${filename}md"

  if ! has_suffix "$filename" "."; then
    basename $1 .md
  elif [ -f "$incomplete_filename" ]; then
    basename $1 .
  else
    echo "Invalid filename: missing suffix?" >&2
    exit 2
  fi
}


# set up fonts
FONTFAMILY=mathpazo
FONTOPTIONS=osf,sc
if [ ${1:-} = "--sans" ]; then
  FONTFAMILY=helvet
  FONTOPTIONS=scaled
  echo '\renewcommand{\familydefault}{\sfdefault}' >> "$TMPHEADER"
  shift
fi

echo FF: $FONTFAMILY >&2
echo FO: $FONTOPTIONS >&2
cat $TMPHEADER >&2

# We have to handle things very differently when we're being used on stdin,
# as pandoc is not UNIX-friendly, i.e. it is sensitive about filenames
if [ $# = 0 ]; then
  # Use stdin
  OUTPUT=$(mktemp --suffix=.pdf)
  INPUT="/dev/stdin"

  cleanup () {
    local ev=$?
    rm -f -- $OUTPUT $TMPINPUT
    exit $ev
  }

  trap cleanup EXIT
else
  BASENAME=$(dirname "$1")/$(source_file_name "$1")
  INPUT=${BASENAME}.md
  OUTPUT=${BASENAME}.pdf
fi

# get started ...
cat "$INPUT" >> $TMPINPUT

SOURCE_DATE_EPOCH=0 \
pandoc -s "$TMPINPUT" \
  --pdf-engine=pdflatex \
  --variable fontfamily="$FONTFAMILY" \
  --variable fontfamilyoptions="$FONTOPTIONS" \
  --metadata title="" \
  --metadata author="" \
  --metadata subject="" \
  --metadata keywords="" \
  -o "$TMPPDF" \
  -V "pdfcreator=" \
  -V "pdfproducer=" \
  -H "$TMPHEADER"

strip-pdf "$TMPPDF" "$OUTPUT"

if [ $# = 0 ]; then
  cat $OUTPUT
fi
